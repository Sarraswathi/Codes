public class LinkedListDemo {
    public static void main(String[] args) {

        LinkedList<Integer>list= new LinkedList<>();

        list.add(10);
        list.add(10);
        list.add(20);
        list.add(30);

        System.out.println(list);

        list.addFirst(70);
        list.addLast(90);

        System.out.println(list);

        list.remove(3);
        System.out.println(list);
        list.removeFirstOccurrence(10);
        System.out.println(list);

        for(Integer n: list){
            System.out.println();
        }
    }

}
